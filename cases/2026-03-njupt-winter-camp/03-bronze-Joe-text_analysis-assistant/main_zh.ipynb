    def run_async_task(self, coro):
        """安全运行异步任务，自动跟踪和清理"""
        task = asyncio.create_task(coro)
        self.active_tasks.append(task)
        
        # 任务完成后自动清理
        def task_cleanup(task):
            if task in self.active_tasks:
                self.active_tasks.remove(task)
        
        task.add_done_callback(task_cleanup)
        return task

