    def markdown_to_html(self, md_text):
        """增强版Markdown转HTML：优化深度分析结果渲染"""
        # 替换标题
        md_text = re.sub(r'^# (.*?)$', r'<h1>\1</h1>', md_text, flags=re.MULTILINE)
        md_text = re.sub(r'^## (.*?)$', r'<h2 style="color: #2c3e50; margin-top: 20px;">\1</h2>', md_text, flags=re.MULTILINE)
        md_text = re.sub(r'^### (.*?)$', r'<h3 style="color: #3498db; margin-top: 15px;">\1</h3>', md_text, flags=re.MULTILINE)
        md_text = re.sub(r'^#### (.*?)$', r'<h4 style="color: #9b59b6; margin-top: 10px;">\1</h4>', md_text, flags=re.MULTILINE)
        
        # 替换无序列表
        md_text = re.sub(r'^- (.*?)$', r'<li style="margin: 5px 0;">\1</li>', md_text, flags=re.MULTILINE)
        md_text = re.sub(r'(<li>.*?</li>)+', r'<ul style="margin: 10px 0; padding-left: 20px;">\g<0></ul>', md_text, flags=re.DOTALL)
        
        # 替换加粗
        md_text = re.sub(r'\*\*(.*?)\*\*', r'<strong style="color: #e74c3c;">\1</strong>', md_text)
        
        # 增强表格渲染
        table_pattern = re.compile(r'\|.*\|.*\|\n\|[-:| ]+\|\n(\|.*\|.*\|\n?)+', re.MULTILINE)
        def render_table(match):
            table_content = match.group()
            # 拆分表头和内容
            rows = table_content.strip().split('\n')
            header_row = rows[0].replace('|', '').strip().split('|')
            header_row = [cell.strip() for cell in header_row if cell.strip()]
            # 移除分隔行
            rows = rows[2:]
            # 构建HTML表格
            html_table = '<table border="1" cellpadding="10" cellspacing="0" width="100%" style="margin: 15px 0; border-collapse: collapse;">'
            # 表头
            html_table += '<tr style="background-color: #f8f9fa;">'
            for header in header_row:
                html_table += f'<th style="border: 1px solid #ddd; text-align: left;">{header}</th>'
            html_table += '</tr>'
            # 内容行
            for row in rows:
                if not row.strip():
                    continue
                cells = row.replace('|', '').strip().split('|')
                cells = [cell.strip() for cell in cells if cell.strip()]
                html_table += '<tr>'
                for cell in cells:
                    html_table += f'<td style="border: 1px solid #ddd; text-align: left;">{cell}</td>'
                html_table += '</tr>'
            html_table += '</table>'
            return html_table
        
        md_text = table_pattern.sub(render_table, md_text)
        
        # 替换引用
        md_text = re.sub(r'^> (.*?)$', r'<blockquote style="margin: 10px 0; padding: 10px 15px; background: #f5f7fa; border-left: 4px solid #3498db;">\1</blockquote>', md_text, flags=re.MULTILINE)
        
        # 替换换行和特殊标记
        md_text = md_text.replace('\n', '<br>')
        md_text = md_text.replace('✅', '&#10004;').replace('❌', '&#10008;').replace('⚠️', '&#9888;')
        
        return md_text

    # 保存功能
    def save_single_result_md(self, _):
        if not self.temp_single_result:
            self.show_save_message("❌ 暂无深度分析结果可保存")
            return
        try:
            filename = self.temp_single_file_info.get("文件名", "未知文件")
            msg = SaveTool.save_analysis_result(filename, self.temp_single_result, self.temp_single_file_info, "md")
            self.show_save_message(msg)
        except Exception as e:
            self.show_save_message(f"❌ 保存失败：{str(e)}")

    def save_single_result_json(self, _):
        if not self.temp_single_result:
            self.show_save_message("❌ 暂无深度分析结果可保存")
            return
        try:
            filename = self.temp_single_file_info.get("文件名", "未知文件")
