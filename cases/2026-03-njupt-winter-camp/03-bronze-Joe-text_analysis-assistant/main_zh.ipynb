class SaveTool:
    @staticmethod
    def save_analysis_result(filename, result, file_info=None, save_type="md"):
        """增强版保存逻辑：包含深度分析维度"""
        try:
            save_dir = "text_analysis_results"
            if not os.path.exists(save_dir):
                os.makedirs(save_dir)
            
            safe_filename = re.sub(r'[\\/:*?"<>|]', '_', filename)
            timestamp = time.strftime("%Y%m%d_%H%M%S")
            
            if save_type == "md":
                md_content = f"# {safe_filename} 文本深度分析报告\n\n"
                md_content += f"## 📋 文件基础信息\n"
                if file_info:
                    for k, v in file_info.items():
                        md_content += f"- {k}：{v}\n"
                md_content += f"\n## 📝 10维度结构化深度分析结果\n"
                if "错误" in result:
                    md_content += f"- ❌ 分析失败：{result['错误']}\n"
                else:
                    # 按分析维度分组展示
                    basic_dimensions = ["摘要", "主题", "关键词", "情感", "文本类型"]
                    deep_dimensions = ["核心论点", "核心论据", "潜在假设", "应用场景", "局限性"]
                    
                    md_content += "### 基础分析维度\n"
                    for key in basic_dimensions:
                        md_content += f"- **{key}**：{result[key]}\n"
                    
                    md_content += "\n### 深度分析维度\n"
                    for key in deep_dimensions:
                        md_content += f"- **{key}**：{result[key]}\n"
                
                md_content += f"\n## ⏱️ 执行信息\n"
                md_content += f"- 处理用时：{result.get('用时', '0秒')}\n"
                md_content += f"- 文本切块数：{result.get('切块数', 1)}\n"
                md_content += f"- 有效块数：{result.get('有效块数', 0)}\n"
                md_content += f"- 加速方式：ROCm GPU加速（办公本适配）\n"
                md_content += f"- 生成时间：{time.strftime('%Y-%m-%d %H:%M:%S')}\n"
                
                save_path = os.path.join(save_dir, f"{safe_filename}_深度分析_{timestamp}.md")
                with open(save_path, "w", encoding="utf-8") as f:
                    f.write(md_content)
                return f"✅ 深度分析报告已保存：{save_path}"
            
            elif save_type == "json":
                save_data = {
                    "文件信息": file_info,
                    "基础分析维度": {k: result[k] for k in ["摘要", "主题", "关键词", "情感", "文本类型"]},
                    "深度分析维度": {k: result[k] for k in ["核心论点", "核心论据", "潜在假设", "应用场景", "局限性"]},
                    "执行信息": {
                        "处理用时": result.get('用时', '0秒'),
                        "文本切块数": result.get('切块数', 1),
                        "有效块数": result.get('有效块数', 0),
                        "生成时间": time.strftime("%Y-%m-%d %H:%M:%S")
                    }
                }
                save_path = os.path.join(save_dir, f"{safe_filename}_深度分析_{timestamp}.json")
                with open(save_path, "w", encoding="utf-8") as f:
                    json.dump(save_data, f, ensure_ascii=False, indent=2)
                return f"✅ 深度分析结果已保存：{save_path}"
            else:
                return "❌ 不支持的保存格式"
        except Exception as e:
            return f"❌ 保存失败：{str(e)}"
    
    @staticmethod
    async def save_compare_result(results, save_type="md"):
        """增强版：异步保存深度对比结果"""
        try:
            save_dir = "text_analysis_results"
            if not os.path.exists(save_dir):
                os.makedirs(save_dir)
            
            timestamp = time.strftime("%Y%m%d_%H%M%S")
            compare_report = await TextComparator.compare(results)
            
            if save_type == "md":
                save_path = os.path.join(save_dir, f"多文本深度对比报告_{timestamp}.md")
                with open(save_path, "w", encoding="utf-8") as f:
                    f.write(compare_report)
                return f"✅ 深度对比报告已保存：{save_path}"
            else:
                return "❌ 深度对比结果仅支持Markdown保存"
        except Exception as e:
            return f"❌ 保存失败：{str(e)}"

