    def save_multi_result(self, _):
        if not self.temp_multi_results:
            self.show_save_message("❌ 暂无深度对比结果可保存", multi=True)
            return
        # 异步保存对比结果
        self.run_async_task(self._async_save_multi_result())

    async def _async_save_multi_result(self):
        """异步保存深度对比结果"""
        try:
            msg = await SaveTool.save_compare_result(self.temp_multi_results, "md")
            self.show_save_message(msg, multi=True)
        except Exception as e:
            self.show_save_message(f"❌ 保存失败：{str(e)}", multi=True)

    def show_save_message(self, msg, multi=False):
        """保存提示：适配深度分析结果"""
        color = "#27ae60" if "✅" in msg else "#e74c3c"
        msg_html = f"""
<div style="padding: 12px; margin: 10px 0; border-radius: 6px; background-color: {color}20; color: {color}; font-size: 14px;">
    {msg}
</div>
        """
        display(HTML(msg_html))
        self.run_async_task(self.hide_save_message())

    async def hide_save_message(self):
        """3秒后自动隐藏保存提示"""
        await asyncio.sleep(3)
        try:
            # 只清理最新的提示框，保留主界面
            clear_output(wait=False)
        except:
            pass

