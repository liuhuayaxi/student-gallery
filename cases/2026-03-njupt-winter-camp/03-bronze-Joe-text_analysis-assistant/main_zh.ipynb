# ====================== 核心配置（通用高性能优化） ======================
class Config:
    # Ollama集群配置
    OLLAMA_API_URL      = "http://open-webui-ollama.open-webui:11434"
    OLLAMA_GENERATE_URL = f"{OLLAMA_API_URL}/api/generate"
    OLLAMA_TAGS_URL     = f"{OLLAMA_API_URL}/api/tags"
    DEFAULT_MODEL       = "qwen3-coder:30b"
    NUM_CTX             = 32768
    API_TIMEOUT         = 180
    PROMPT_RESERVE      = 1000
    MAX_RETRIES         = 2
    RETRY_DELAY         = 1.5
    RATE_LIMIT          = 6
    RATE_WINDOW         = 60
    TASK_TIMEOUT        = 300  # 任务超时时间（5分钟）

    # ROCm加速配置
    os.environ["HIP_VISIBLE_DEVICES"] = "0"        
    os.environ["OLLAMA_HF_DEVICE_MAP"] = "auto"    
    os.environ["PYTORCH_ROCM_ARCH"] = "gfx906"     
    os.environ["OLLAMA_GPU"] = "1"                 

# ====================== 环境检测 ======================
class EnvChecker:
    @staticmethod
    async def check_all():
        """完整环境检测：ROCm+Ollama+模型+网络"""
        results = {
            "ROCm加速": EnvChecker.check_rocm(),
            "Ollama服务": await EnvChecker.check_ollama_service(),
            "模型可用性": await EnvChecker.check_model(),
            "网络连通性": await EnvChecker.check_network()
        }
        return results

    @staticmethod
    def check_rocm():
        """检测ROCm加速是否生效"""
        try:
            if "HIP_VISIBLE_DEVICES" not in os.environ:
                return "❌ 未启用（环境变量未设置）"
            
            try:
                result = subprocess.run(
                    ["rocminfo"], 
                    capture_output=True, 
                    text=True,
                    timeout=10
                )
            except (subprocess.TimeoutExpired, FileNotFoundError):
                return "⚠️ ROCm工具未安装/超时（不影响CPU运行）"
            
            if result.returncode == 0 and result.stdout and "gfx" in result.stdout:
                return "✅ 已启用（GPU加速生效）"
            else:
                return "⚠️ 未检测到ROCm设备（将使用CPU）"
        except Exception as e:
            return f"❌ 检测失败：{str(e)[:20]}"

    @staticmethod
    async def check_ollama_service():
        """检测Ollama服务可达性"""
        try:
            timeout = ClientTimeout(total=5)
            async with aiohttp.ClientSession(timeout=timeout) as session:
                resp = await session.get(Config.OLLAMA_API_URL)
                if resp.status == 200:
                    return "✅ 服务正常"
                else:
                    return f"❌ 状态码：{resp.status}"
        except asyncio.TimeoutError:
            return "❌ 连接超时（服务未响应）"
        except Exception as e:
            return f"❌ 连接失败：{str(e)[:20]}"

    @staticmethod
    async def check_model():
        """检测模型是否已下载"""
        try:
            timeout = ClientTimeout(total=5)
            async with aiohttp.ClientSession(timeout=timeout) as session:
                resp = await session.get(Config.OLLAMA_TAGS_URL)
                if resp.status == 200:
                    data = await resp.json()
                    models = [m["name"] for m in data.get("models", [])]
                    if Config.DEFAULT_MODEL in models:
                        return "✅ 模型已下载"
                    else:
                        return f"❌ 模型缺失（执行：ollama pull {Config.DEFAULT_MODEL}）"
                else:
                    return f"❌ 接口异常：{resp.status}"
        except asyncio.TimeoutError:
            return "❌ 模型检测超时"
        except Exception as e:
            return f"❌ 检测失败：{str(e)[:20]}"

    @staticmethod
    async def check_network():
        """检测集群内网连通性"""
        try:
            timeout = ClientTimeout(total=3)
            async with aiohttp.ClientSession(timeout=timeout) as session:
                await session.get(f"{Config.OLLAMA_API_URL}/api/tags")
                return "✅ 内网连通"
        except asyncio.TimeoutError:
            return "❌ 网络超时"
        except Exception as e:
            return f"❌ 网络不通：{str(e)[:20]}"

# ====================== 异步重试+超时装饰器 ======================
def async_retry_with_timeout(max_retries=Config.MAX_RETRIES, delay=Config.RETRY_DELAY, timeout=Config.TASK_TIMEOUT):
    def decorator(func):
        @wraps(func)
        async def wrapper(*args, **kwargs):
            # 任务超时控制
            async def task_with_timeout():
                for attempt in range(max_retries):
                    try:
                        return await func(*args, **kwargs)
                    except Exception as e:
                        if attempt == max_retries - 1:
                            raise Exception(f"重试{max_retries}次失败：{str(e)}")
                        await asyncio.sleep(delay * (attempt + 1))
                return None
            
            try:
                # 超时强制终止任务
                return await asyncio.wait_for(task_with_timeout(), timeout=timeout)
            except asyncio.TimeoutError:
                raise Exception(f"任务超时（{timeout}秒），已自动终止")
        return wrapper
    return decorator

# ====================== 限流控制 ======================
class RateLimiter:
    def __init__(self, max_requests=Config.RATE_LIMIT, time_window=Config.RATE_WINDOW):
        self.max_requests = max_requests
        self.time_window = time_window
        self.request_timestamps = deque()
        self.lock = asyncio.Lock()  # 加锁防止并发问题

    async def acquire(self):
        """异步获取限流许可"""
        async with self.lock:
            now = time.time()
            # 清理过期请求
            while self.request_timestamps and now - self.request_timestamps[0] > self.time_window:
                self.request_timestamps.popleft()
            # 限流等待
            if len(self.request_timestamps) >= self.max_requests:
                wait_time = self.time_window - (now - self.request_timestamps[0])
                await asyncio.sleep(wait_time + 0.5)
            self.request_timestamps.append(now)

rate_limiter = RateLimiter()

# ====================== Token工具 ======================
class Tokenizer:
    _encoder = None

    @staticmethod
    def get_encoder():
        if not Tokenizer._encoder:
            try:
                Tokenizer._encoder = tiktoken.encoding_for_model("qwen-32k")
            except:
                Tokenizer._encoder = tiktoken.get_encoding("cl100k_base")
        return Tokenizer._encoder

    @staticmethod
    def count(text):
        """计算Token数量"""
        return len(Tokenizer.get_encoder().encode(text))

    @staticmethod
    def truncate(text, max_tokens):
        """截断文本到指定Token数（保留完整句子）"""
        encoder = Tokenizer.get_encoder()
        tokens = encoder.encode(text)
        if len(tokens) <= max_tokens:
            return text
        truncated = encoder.decode(tokens[:max_tokens])
        end_chars = {'.', '。', '！', '？', ';', '；'}
        last_pos = max([truncated.rfind(c) for c in end_chars] + [max_tokens - 10])
        return truncated[:last_pos + 1].strip()

# ====================== 文本切块（修复超长文本切分） ======================
class TextSplitter:
    @staticmethod
    def split(text, overlap_ratio=0.15):
        """
        超长文本智能切分（适配32k Token）
        策略优先级：段落 > 句子 > Token，保证语义完整性+Token精准控制
        """
        # 1. 基础计算：获取Prompt占用Token数，计算单块最大Token数
        prompt_base = TextAnalyzer.build_prompt("")
        prompt_tokens = Tokenizer.count(prompt_base)
        # 【调整1】将单块Token上限从32768改为16384，适配42000Token超长文本
        max_chunk_tokens = 16384 - prompt_tokens - Config.PROMPT_RESERVE
        if max_chunk_tokens <= 0:
            max_chunk_tokens = 16384 - 2000  # 兜底值同步调整
        
        # 2. 预处理：清理多余换行，按段落拆分
        text = re.sub(r'\n+', '\n', text).strip()  # 合并多换行
        paragraphs = [p.strip() for p in text.split('\n') if p.strip()]  # 按段落拆分
        
        chunks = []
        current_chunk = ""
        current_tokens = 0
        overlap_tokens = int(max_chunk_tokens * overlap_ratio)  # 按Token数计算重叠
        
        for para in paragraphs:
            para_tokens = Tokenizer.count(para)
            
            # 情况1：当前段落本身超Token上限 → 拆句子
            if para_tokens > max_chunk_tokens:
                # 先把当前已攒的chunk存入
                if current_chunk:
                    chunks.append(current_chunk)
                    # 计算重叠内容（取最后N个Token）
                    overlap_text = TextSplitter._get_overlap_text(current_chunk, overlap_tokens)
                    current_chunk = overlap_text
                    current_tokens = Tokenizer.count(current_chunk)
                
                # 拆分超长段落（按句子）
                sentences = re.split(r'(?<=[。！？;.!?])\s*', para)
                for sent in sentences:
                    sent_tokens = Tokenizer.count(sent)
                    # 句子本身超上限 → Token级截断
                    if sent_tokens > max_chunk_tokens:
                        if current_chunk:
                            chunks.append(current_chunk)
                            current_chunk = ""
                            current_tokens = 0
                        # 按Token截断，保留完整语义（找最近的标点）
                        truncated = Tokenizer.truncate(sent, max_chunk_tokens)
                        chunks.append(truncated)
                        continue
                    
                    # 句子+当前chunk超上限 → 保存当前chunk，重置
                    if current_tokens + sent_tokens > max_chunk_tokens:
                        chunks.append(current_chunk)
                        # 重叠：取当前chunk最后N个Token
                        overlap_text = TextSplitter._get_overlap_text(current_chunk, overlap_tokens)
                        current_chunk = overlap_text + sent
                        current_tokens = Tokenizer.count(current_chunk)
                    else:
                        current_chunk += (" " if current_chunk else "") + sent
                        current_tokens += sent_tokens
            
            # 情况2：当前段落可加入chunk
            else:
                if current_tokens + para_tokens > max_chunk_tokens:
                    # 保存当前chunk
                    chunks.append(current_chunk)
                    # 重叠：取当前chunk最后N个Token
                    overlap_text = TextSplitter._get_overlap_text(current_chunk, overlap_tokens)
                    current_chunk = overlap_text + para
                    current_tokens = Tokenizer.count(current_chunk)
                else:
                    current_chunk += ("\n" if current_chunk else "") + para
                    current_tokens += para_tokens
        
        # 加入最后一个chunk
        if current_chunk.strip():
            chunks.append(current_chunk.strip())
        
        # 去重+过滤空块
        chunks = [c.strip() for c in chunks if c.strip()]
        return chunks
    
    @staticmethod
    def _get_overlap_text(text, overlap_tokens):
        """获取文本最后N个Token的内容（保证语义完整）"""
        if overlap_tokens <= 0 or not text:
            return ""
        
        tokens = Tokenizer.get_encoder().encode(text)
        if len(tokens) <= overlap_tokens:
            return text
        
        # 取最后N个Token，解码后找最近的标点，保证语义完整
        overlap_token_list = tokens[-overlap_tokens:]
        overlap_text = Tokenizer.get_encoder().decode(overlap_token_list)
        
        # 找最后一个标点，从标点后开始（避免截断句子）
        end_chars = {'.', '。', '！', '？', ';', '；', '\n'}
        last_pos = max([overlap_text.rfind(c) for c in end_chars] + [-1])
        if last_pos >= 0:
            overlap_text = overlap_text[last_pos+1:].strip()
        
        return overlap_text

# ====================== 文本分析（核心升级：深度Prompt） ======================
class TextAnalyzer:
    @staticmethod
    def build_prompt(text):
        """
        增强版深度分析Prompt
        包含：System Role + 思维链引导 + 中英文Few-shot + 严格输出格式
        """
        # System Role：定义专业文本分析专家角色
        system_role = """
<system>
你是一位资深的多语言文本分析专家，擅长中英文文本的深度结构化分析。
你的分析需要遵循以下思维链（CoT）步骤：
1. 理解文本类型：判断文本是学术论文、行业报告、新闻资讯、商业文档还是其他类型
2. 提取核心信息：识别文本的核心主题、关键数据、核心观点
3. 深度分析：挖掘文本的潜在假设、核心论据、逻辑结构
4. 价值评估：分析文本的应用场景、局限性、潜在价值
5. 结构化输出：按照指定格式输出所有分析维度，确保内容详实、逻辑清晰

分析要求：
- 支持中英文混合文本，输出语言与文本主要语言保持一致
- 摘要需客观全面，50-80字，覆盖核心内容和关键结论
- 关键词需精准，10-15个，覆盖核心概念和维度
- 所有分析维度需有深度，避免表面化描述
- 严格按照指定格式输出，不要添加任何额外内容
</system>
"""
        
        # Few-shot范例：中英文各一个，引导深度分析
        few_shot_examples = """
<examples>
【中文范例输入】
人工智能技术在医疗领域的应用正在快速发展。基于大语言模型的辅助诊断系统能够将医生的诊断效率提升30%，同时降低误诊率约15%。但该技术仍面临数据隐私、算法偏见和监管合规等挑战，且在基层医疗机构的落地成本较高。

【中文范例输出】
摘要：人工智能技术在医疗领域应用加速，大语言模型辅助诊断系统可提升30%诊断效率、降低15%误诊率，但面临数据隐私、算法偏见等挑战，基层落地成本高。
主题：人工智能、医疗应用、大语言模型
关键词：人工智能、医疗、大语言模型、辅助诊断、诊断效率、误诊率、数据隐私、算法偏见、监管合规、基层医疗、落地成本
情感：客观中立
文本类型：行业分析
核心论点：AI医疗技术成效显著但存在多维度挑战
核心论据：诊断效率提升30%、误诊率降低15%、数据隐私问题、算法偏见、监管合规、基层落地成本高
潜在假设：AI技术可有效弥补医疗资源不足、医疗数据可合规使用
应用场景：三甲医院辅助诊断、医疗数据分析、医疗政策制定
局限性：数据隐私风险、算法偏见、基层落地成本高、监管政策不完善

【英文范例输入】
The development of renewable energy technologies has significantly reduced carbon emissions in the power sector. Solar energy generation costs have dropped by 80% over the past decade, making it competitive with fossil fuels in many regions. However, energy storage capacity and grid integration remain major bottlenecks, especially in areas with unstable power demand.

【英文范例输出】
摘要：Renewable energy technologies have reduced power sector carbon emissions significantly, with solar energy costs dropping 80% in a decade and becoming competitive with fossil fuels, but energy storage and grid integration are major bottlenecks, especially in regions with unstable power demand.
主题：Renewable Energy, Carbon Emissions, Solar Energy
关键词：Renewable energy, carbon emissions, power sector, solar energy, generation costs, fossil fuels, energy storage, grid integration, power demand, competitiveness
情感：Objective and neutral
文本类型：Industry Report
核心论点：Renewable energy has made significant progress but faces storage and grid integration challenges
核心论据：80% drop in solar energy costs, competitiveness with fossil fuels, energy storage bottlenecks, grid integration issues, unstable power demand
潜在假设：Renewable energy can replace fossil fuels, grid infrastructure can be upgraded to support renewable energy
应用场景：Energy policy formulation, power sector investment, renewable energy project planning
局限性：Insufficient energy storage capacity, grid integration difficulties, unstable power demand, regional disparities
</examples>
"""
        
        # 输出格式：扩展到10个维度，增加深度分析项
        output_format = """
## 待分析文本：
{text}

## 输出格式（严格遵守，仅保留以下内容，不要添加任何额外说明）：
摘要：<内容>
主题：<内容>
关键词：<内容>
情感：<内容>
文本类型：<内容>
核心论点：<内容>
核心论据：<内容>
潜在假设：<内容>
应用场景：<内容>
局限性：<内容>
"""
        
        # 组合完整Prompt
        full_prompt = f"{system_role}{few_shot_examples}{output_format.format(text=text)}"
        return full_prompt.strip()

    @staticmethod
    def parse_result(raw_output):
        """增强版解析逻辑：适配10个深度分析维度"""
        result = {
            "摘要": "无",
            "主题": "无",
            "关键词": "无",
            "情感": "无",
            "文本类型": "无",
            "核心论点": "无",
            "核心论据": "无",
            "潜在假设": "无",
            "应用场景": "无",
            "局限性": "无",
            "用时": "0秒",
            "切块数": 0,
            "有效块数": 0
        }
        
        # 解析所有维度，支持中英文冒号（：/:）
        for key in result.keys():
            if key in ["用时", "切块数", "有效块数"]:
                continue
            # 兼容中英文冒号和可能的空格
            pattern = re.compile(f"{key}\\s*[:：]\\s*(.*?)(?=\\n|$)", re.DOTALL)
            match = pattern.search(raw_output)
            if match:
                result[key] = match.group(1).strip()
        
        return result

    @staticmethod
    @async_retry_with_timeout()
    async def call_ollama(prompt):
        """异步调用Ollama API（带超时+重试）"""
        await rate_limiter.acquire()
        timeout = ClientTimeout(total=Config.API_TIMEOUT)
        async with aiohttp.ClientSession(timeout=timeout) as session:
            response = await session.post(
                Config.OLLAMA_GENERATE_URL,
                json={
                    "model": Config.DEFAULT_MODEL,
                    "prompt": prompt,
                    "stream": False,
                    "num_ctx": Config.NUM_CTX,
                    "temperature": 0.1,  # 降低随机性，提升分析稳定性
                    "top_p": 0.95,
                    "max_tokens": 4096  # 增加输出长度，支持深度分析
                }
            )
            if response.status != 200:
                raise Exception(f"API错误：状态码{response.status}")
            data = await response.json()
            response_text = data.get("response", "").strip()
            if not response_text:
                raise Exception("模型返回空响应")
            return response_text

    @staticmethod
    async def analyze(text):
        """增强版级联分析流程（支持深度分析）"""
        start_time = time.time()
        chunks = TextSplitter.split(text)
        if not chunks:
            return {"错误": "无有效文本可分析", "用时": f"{time.time()-start_time:.2f}秒"}
        
        # 逐块深度分析（过滤无效内容）
        chunk_results = []
        for idx, chunk in enumerate(chunks):
            try:
                prompt = TextAnalyzer.build_prompt(chunk)
                raw = await TextAnalyzer.call_ollama(prompt)
                parsed = TextAnalyzer.parse_result(raw)
                # 过滤无效块（摘要为空或核心论点为空）
                if parsed["摘要"] == "无" or parsed["核心论点"] == "无":
                    continue
                chunk_results.append(parsed)
            except Exception as e:
                print(f"块{idx+1}分析失败：{str(e)[:50]}")
                continue
        
        # 无有效块直接返回错误
        if not chunk_results:
            return {
                "错误": "所有切块分析无效（文本过短/为空/模型未返回有效内容）",
                "用时": f"{time.time()-start_time:.2f}秒"
            }
        
        # 级联汇总：基于所有块的深度分析结果生成整体结论
        summary_lines = []
        for idx, cr in enumerate(chunk_results, 1):
            summary_lines.append(f"""
【块{idx}分析结果】
摘要：{cr['摘要']}
主题：{cr['主题']}
核心论点：{cr['核心论点']}
核心论据：{cr['核心论据']}
潜在假设：{cr['潜在假设']}
应用场景：{cr['应用场景']}
局限性：{cr['局限性']}
""")
        
        # 级联Prompt：引导整合所有块的深度分析结果
        cascade_prompt = f"""
<system>
你是文本分析整合专家，需要基于多个文本块的深度分析结果，生成整体的结构化分析结论。
整合要求：
1. 摘要需全面覆盖所有块的核心内容，80-100字
2. 主题需提炼所有块的共同核心，避免碎片化
3. 核心论点需整合所有块的观点，形成完整逻辑
4. 所有维度需有深度，体现文本的整体价值和局限性
5. 严格按照指定格式输出，不要添加额外内容
</system>

<analysis_results>
{chr(10).join(summary_lines)}
</analysis_results>

## 输出格式（严格遵守）：
摘要：<整体核心摘要>
主题：<整体核心主题>
关键词：<整体关键词，中文逗号分隔>
情感：<整体情感倾向>
文本类型：<整体文本类型>
核心论点：<整体核心观点>
核心论据：<整体核心论据>
潜在假设：<整体潜在假设>
应用场景：<整体应用场景>
局限性：<整体局限性>
"""
        
        try:
            cascade_raw = await TextAnalyzer.call_ollama(cascade_prompt)
            final_result = TextAnalyzer.parse_result(cascade_raw)
            final_result["切块数"] = len(chunks)
            final_result["有效块数"] = len(chunk_results)
            final_result["用时"] = f"{time.time()-start_time:.2f}秒"
            return final_result
        except Exception as e:
            return {
                "错误": f"级联分析失败：{str(e)[:30]}",
                "用时": f"{time.time()-start_time:.2f}秒"
            }

# ====================== 通用对比分析（增强版：深度对比） ======================
class TextComparator:
    @staticmethod
    async def compare(results):
        """增强版：深度多文本对比分析"""
        # 基础校验
        valid_results = {k: v for k, v in results.items() if "错误" not in v}
        file_count = len(valid_results)
        
        # 报告标题
        report = [
            "# 📊 多文本深度结构化对比分析报告",
            "",
            f"> 本次分析共处理 {len(results)} 个文件，其中有效分析 {file_count} 个，分析失败 {len(results)-file_count} 个。",
            "> 分析说明：基于文本深度分析结果，自动识别核心共性、关键差异、潜在冲突和互补价值，适配中英文文本。"
        ]
        
        if file_count >= 2:
            # 提取所有有效文本的深度分析信息
            file_names = sorted(list(valid_results.keys()))
            file_summaries = []
            for idx, fname in enumerate(file_names, 1):
                res = valid_results[fname]
                summary = f"""
### 文本{idx}：{fname}
- 核心主题：{res['主题']}
- 文本类型：{res['文本类型']}
- 核心论点：{res['核心论点']}
- 核心论据：{res['核心论据']}
- 潜在假设：{res['潜在假设']}
- 应用场景：{res['应用场景']}
- 局限性：{res['局限性']}
- 情感倾向：{res['情感']}
"""
                file_summaries.append(summary.strip())
            
            # 增强版Few-Shot对比Prompt：深度对比引导
            cascade_prompt = f"""
<system>
你是多文本深度对比分析专家，擅长识别多个文本之间的核心共性、关键差异、潜在冲突和互补价值。
对比分析需遵循以下思维链（CoT）：
1. 共性分析：识别所有文本的共同主题、相似论点、一致的潜在假设
2. 差异分析：对比文本在核心论据、应用场景、局限性等维度的关键差异
3. 冲突分析：识别文本之间的观点冲突、论据矛盾（如有）
4. 互补分析：分析文本之间的互补价值、协同应用场景
5. 综合评估：给出整体的对比结论和应用建议

输出要求：
1. 严格按照指定格式输出，包含所有对比维度
2. 对比需有深度，避免表面化描述
3. 支持中英文混合文本，输出语言与主要文本保持一致
4. 差异分析部分必须包含表格对比，清晰展示各维度差异
</system>

## Few-Shot深度对比范例
### 范例输入（2个文本）：
文本1：AI医疗应用分析
- 核心主题：人工智能、医疗应用、大语言模型
- 文本类型：行业分析
- 核心论点：AI医疗技术成效显著但存在多维度挑战
- 核心论据：诊断效率提升30%、误诊率降低15%、数据隐私问题
- 潜在假设：AI技术可有效弥补医疗资源不足
- 应用场景：三甲医院辅助诊断、医疗数据分析
- 局限性：数据隐私风险、基层落地成本高
- 情感倾向：客观中立

文本2：AI教育应用分析
- 核心主题：人工智能、教育应用、个性化学习
- 文本类型：行业分析
- 核心论点：AI教育技术可实现个性化学习但面临公平性挑战
- 核心论据：学习效率提升25%、个性化推荐准确率80%、教育公平问题
- 潜在假设：AI技术可适配不同学习能力的学生
- 应用场景：K12教育、职业培训、在线教育平台
- 局限性：数字鸿沟、算法偏见、教师角色弱化
- 情感倾向：客观中立

### 范例输出：
## 1. 核心共性分析
- 共同主题：均围绕人工智能技术在垂直领域的应用展开，聚焦技术价值与挑战
- 相似论点：AI技术在特定领域成效显著，但均面临多维度的应用挑战
- 一致假设：均假设AI技术能够提升行业效率，弥补传统模式的不足
- 情感倾向：均保持客观中立的分析视角

## 2. 关键差异分析
### 2.1 核心维度对比表
| 对比维度 | 文本1：AI医疗应用分析 | 文本2：AI教育应用分析 |
|----------|------------------------------|------------------------------|
| 核心领域 | 医疗健康（诊断效率、误诊率） | 教育学习（学习效率、个性化） |
| 核心数据 | 诊断效率+30%、误诊率-15% | 学习效率+25%、推荐准确率80% |
| 主要挑战 | 数据隐私、基层落地成本 | 数字鸿沟、算法偏见、教师角色 |
| 应用场景 | 三甲医院、医疗数据分析 | K12教育、职业培训、在线教育 |
| 潜在风险 | 医疗事故风险、监管合规 | 教育公平风险、人文关怀缺失 |

### 2.2 深层差异解读
- 价值维度：医疗领域侧重生命健康价值，教育领域侧重知识获取效率
- 风险维度：医疗领域风险更直接（生命安全），教育领域风险更长期（社会公平）
- 落地难度：医疗领域落地受硬件成本制约，教育领域受数字鸿沟制约

## 3. 潜在冲突分析
- 无直接观点冲突：两个文本聚焦不同领域，核心论点和论据无直接矛盾
- 间接冲突点：资源分配优先级冲突（医疗AI vs 教育AI的资源投入）

## 4. 互补价值分析
- 技术互补：医疗AI的隐私保护技术可迁移至教育AI场景
- 应用互补：AI技术在医疗和教育的协同应用可实现全生命周期的智能服务
- 方法论互补：两个领域的挑战分析方法可互相借鉴，提升AI应用的全面性

## 5. 综合评估与建议
- 核心结论：AI技术在垂直领域应用价值显著，但需针对不同领域的特性制定差异化的风险管控策略
- 应用建议：1) 建立跨领域的AI伦理规范；2) 优先解决高风险维度的挑战；3) 推动AI技术在不同领域的经验共享

